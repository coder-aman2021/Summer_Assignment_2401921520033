
//1. Construct a Binary trees from inorder and preorder traversal
class Solution {
      int preIndex = 0;
      public TreeNode build(int[] preorder, int[] inorder, int start, int end){

        if(start > end)
            return null;


        int value = preorder[preIndex];

        TreeNode root = new TreeNode(value);

        preIndex++;


        int index = 0;

        for(int i=start; i<=end; i++){
            if(inorder[i] == value){
                index = i;
                break;
            }
        }


        root.left = build(preorder, inorder, start, index-1);

        root.right = build(preorder, inorder, index+1, end);


        return root;
    }
    public TreeNode buildTree(int[] preorder, int[] inorder) {
         return build(preorder, inorder, 0, inorder.length-1);
    }
}
