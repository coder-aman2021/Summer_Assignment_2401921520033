//1. Path sum
import java.util.* ;
class Solution {
    public boolean hasPathSum(TreeNode root, int targetSum) {
      if(root==null)
      return false ;
     Stack<TreeNode> path  = new Stack<>()  ; 
     Stack<Integer> pathsum = new Stack<>() ;
     path.add(root)    ;
     pathsum.add(root.val) ;
     while(!path.isEmpty()){
        TreeNode temp = path.pop() ;
        int sum = pathsum.pop() ;
        if(temp.right==null&&temp.left==null&&sum==targetSum)
        return true ;
        if(temp.right!=null){
            path.add(temp.right);
            pathsum.add(temp.right.val + sum) ;
        }
        if(temp.left!=null){
            path.add(temp.left);
            pathsum.add(temp.left.val + sum) ;
        }
     }
     return false ;
    }
}
